generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js tables ───────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  settings       Json      @default("{}")
  paperBalance   Float     @default(10000)
  startingBalance Float    @default(10000)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  positions     Position[]
  journalEntries JournalEntry[]
  priceAlerts   PriceAlert[]
  customIndicators CustomIndicator[]
  tradingBots   TradingBot[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Domain tables ────────────────────────────────────────────

model Position {
  id               String    @id @default(cuid())
  userId           String
  botId            String?   // null = manual trade, set = bot-placed
  asset            String    // "BTCUSDT"
  side             String    // "LONG" | "SHORT"
  size             Float
  entry            Float
  exit             Float?
  stopLoss         Float?
  takeProfit       Float?
  trailingDistance Float?    // price distance for trailing stop (absolute)
  trailingHighWater Float?   // best price reached (high for LONG, low for SHORT)
  pnl              Float?
  status           String    @default("active") // "active" | "closed"
  openedAt         DateTime  @default(now())
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot  TradingBot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, openedAt])
  @@index([botId])
}

model TradingBot {
  id              String    @id @default(cuid())
  userId          String
  name            String

  // Symbol filter — empty = all configured pairs
  symbols         String[]  @default([])

  // Trigger
  // mtf_aligned     — composite multi-TF bias matches `side` and confidence ≥ minConfidence
  // single_tf_bias  — only `tfFilter` timeframe must match
  // rsi_extreme     — fire on RSI overbought/oversold on `tfFilter`
  triggerType     String    @default("mtf_aligned")
  tfFilter        String    @default("4h")  // for single-TF / RSI triggers
  minConfidence   Int       @default(70)    // 0–99

  // Side preference: "ANY" follows bias, or force "LONG" / "SHORT"
  side            String    @default("ANY")

  // Trade params
  positionSizePct Float     @default(5)     // % of paper balance per trade
  stopLossPct     Float?                    // SL as % from entry (always positive)
  takeProfitPct   Float?                    // TP as %
  trailingPct     Float?                    // trailing stop %

  // Concurrency
  maxOpenPositions Int      @default(1)     // bot won't open if it already has N active
  cooldownMinutes  Int      @default(60)    // wait N minutes after a trade before next

  // State
  enabled         Boolean   @default(true)
  lastRunAt       DateTime?
  lastTradeAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@index([userId, enabled])
}

model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  symbol      String    // "BTCUSDT"
  price       Float
  direction   String    // "above" | "below"
  message     String?
  active      Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([userId, symbol])
}

model CustomIndicator {
  id         String   @id @default(cuid())
  userId     String
  name       String
  expression String   @db.Text
  color      String   @default("#00ffff")
  overlay    Boolean  @default(true)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  displayId  String   // "K-9201"
  date       DateTime
  pair       String   // "BTC/USD"
  side       String   // "LONG" | "SHORT"
  entry      Float
  exit       Float
  pnl        Float
  pnlPct    Float
  rrr        String   // "1:3.2"
  strategy   String
  notes      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
